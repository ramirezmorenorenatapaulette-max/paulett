<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mini Geometry Dash</title>
<style>
body{
    margin:0;
    overflow:hidden;
    background:#111;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    font-family:Arial,sans-serif;
}

canvas{
    background:linear-gradient(#1e1e1e,#333);
    border:3px solid white;
}

#info{
    position:absolute;
    top:20px;
    color:white;
    font-size:24px;
}
</style>
</head>
<body>

<div id="info">Puntos: <span id="score">0</span></div>
<canvas id="game" width="900" height="400"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
const scoreText = document.getElementById("score");

const groundY = 320;

let player = {
    x:100,
    y:groundY-40,
    w:40,
    h:40,
    velY:0,
    jumping:false,
    rotation:0
};

let gravity = 0.8;
let jumpForce = -14;

let obstacles = [];
let score = 0;
let speed = 6;
let gameOver = false;

function createObstacle(){
    obstacles.push({
        x:canvas.width,
        y:groundY-40,
        w:35,
        h:40
    });
}

setInterval(()=>{
    if(!gameOver){
        createObstacle();
    }
}, 1500);

document.addEventListener("keydown", jump);
document.addEventListener("click", jump);

function jump(){
    if(!player.jumping && !gameOver){
        player.velY = jumpForce;
        player.jumping = true;
    }

    if(gameOver){
        restart();
    }
}

function restart(){
    obstacles = [];
    score = 0;
    speed = 6;
    gameOver = false;

    player.y = groundY-40;
    player.velY = 0;
    player.jumping = false;
    player.rotation = 0;
}

function update(){

    if(gameOver) return;

    player.velY += gravity;
    player.y += player.velY;

    if(player.y >= groundY-player.h){
        player.y = groundY-player.h;
        player.velY = 0;
        player.jumping = false;
        player.rotation = 0;
    }else{
        player.rotation += 0.15;
    }

    for(let i=obstacles.length-1;i>=0;i--){
        let o = obstacles[i];
        o.x -= speed;

        if(o.x + o.w < 0){
            obstacles.splice(i,1);
            score++;
            scoreText.textContent = score;

            if(score % 5 === 0){
                speed += 0.5;
            }
        }

        if(
            player.x < o.x + o.w &&
            player.x + player.w > o.x &&
            player.y < o.y + o.h &&
            player.y + player.h > o.y
        ){
            gameOver = true;
        }
    }
}

function draw(){

    ctx.clearRect(0,0,canvas.width,canvas.height);

    // suelo
    ctx.fillStyle = "#00ff88";
    ctx.fillRect(0,groundY,canvas.width,6);

    // jugador
    ctx.save();
    ctx.translate(
        player.x + player.w/2,
        player.y + player.h/2
    );
    ctx.rotate(player.rotation);
    ctx.fillStyle = "#00aaff";
    ctx.fillRect(
        -player.w/2,
        -player.h/2,
        player.w,
        player.h
    );
    ctx.restore();

    // obstáculos
    ctx.fillStyle = "#ff4444";

    obstacles.forEach(o=>{
        ctx.beginPath();
        ctx.moveTo(o.x,o.y+o.h);
        ctx.lineTo(o.x+o.w/2,o.y);
        ctx.lineTo(o.x+o.w,o.y+o.h);
        ctx.fill();
    });

    if(gameOver){
        ctx.fillStyle="white";
        ctx.font="48px Arial";
        ctx.textAlign="center";
        ctx.fillText(
            "GAME OVER",
            canvas.width/2,
            150
        );

        ctx.font="24px Arial";
        ctx.fillText(
            "Presiona ESPACIO o CLICK para reiniciar",
            canvas.width/2,
            210
        );
    }
}

function loop(){
    update();
    draw();
    requestAnimationFrame(loop);
}

loop();
</script>

</body>
</html>
